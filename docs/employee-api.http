@baseUrl = http://localhost:5000/api
@employeeId = 1

### Health check
GET {{baseUrl}}/health
Accept: application/json

### List departments and positions for the dropdowns
GET {{baseUrl}}/departments
Accept: application/json

### List employees
GET {{baseUrl}}/employees?page=1&pageSize=10
Accept: application/json

### Search active employees
GET {{baseUrl}}/employees?search=finance&status=1&page=1&pageSize=10
Accept: application/json

### Create employee
POST {{baseUrl}}/employees
Content-Type: application/json
Accept: application/json

{
  "employeeNumber": "EMP-011",
  "firstName": "Liza",
  "lastName": "Cruz",
  "positionId": "5",
  "status": 1,
  "joinDate": "2026-07-21"
}

### Update employee
PUT {{baseUrl}}/employees/{{employeeId}}
Content-Type: application/json
Accept: application/json

{
  "employeeNumber": "EMP-001",
  "firstName": "Juan",
  "lastName": "Dela Cruz",
  "positionId": "1",
  "status": 1,
  "joinDate": "2026-07-21"
}

### Permanently delete employee
DELETE {{baseUrl}}/employees/{{employeeId}}
Accept: application/json
