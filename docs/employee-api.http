@baseUrl = http://localhost:5000/api
@employeeId = 1

### Health check
GET {{baseUrl}}/health
Accept: application/json

### List departments and positions
GET {{baseUrl}}/departments
Accept: application/json

### List all employees
GET {{baseUrl}}/employees
Accept: application/json

### Create employee
### PostgreSQL generates employeeId automatically
POST {{baseUrl}}/employees
Content-Type: application/json
Accept: application/json

{
  "firstName": "Liza",
  "lastName": "Cruz",
  "positionId": "5",
  "status": 1,
  "joinDate": "2026-07-21"
}

### Update employee using employeeId in the URL
PUT {{baseUrl}}/employees/{{employeeId}}
Content-Type: application/json
Accept: application/json

{
  "firstName": "Juan",
  "lastName": "Dela Cruz",
  "positionId": "1",
  "status": 1,
  "joinDate": "2026-07-21"
}

### Delete employee using employeeId in the URL
DELETE {{baseUrl}}/employees/{{employeeId}}
Accept: application/json
